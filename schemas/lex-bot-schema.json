{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lex V2 Bot Configuration",
  "type": "object",
  "additionalProperties": false,

  "required": ["name", "idle_session_ttl", "locales"],

  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9_-]+$"
    },

    "description": {
      "type": "string",
      "maxLength": 200
    },

    "type": {
      "type": "string",
      "enum": ["Bot", "BotNetwork"],
      "default": "Bot"
    },

    "idle_session_ttl": {
      "type": "integer",
      "minimum": 60,
      "maximum": 86400
    },

    "child_directed": {
      "type": "boolean",
      "default": false
    },

    "logging": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "log_level": {
          "type": "string",
          "enum": ["INFO", "ERROR"]
        }
      }
    },

    "locales": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": false,

      "patternProperties": {
        "^[a-z]{2}_[A-Z]{2}$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["confidence_threshold"],

          "properties": {
            "description": { "type": "string" },

            "confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },

            "voice_settings": {
              "type": "object",
              "additionalProperties": false,
              "required": ["voice_id"],
              "properties": {
                "voice_id": { "type": "string" },
                "engine": {
                  "type": "string",
                  "enum": ["standard", "neural"]
                }
              }
            },

            "custom_vocabulary": {
              "type": "array",
              "maxItems": 100,
              "items": {
                "type": "object",
                "required": ["phrase"],
                "additionalProperties": false,
                "properties": {
                  "phrase": { "type": "string" },
                  "display_as": { "type": "string" },
                  "weight": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 3
                  }
                }
              }
            },

            "slot_types": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["values"],

                "properties": {
                  "description": { "type": "string" },

                  "value_selection_strategy": {
                    "type": "string",
                    "enum": ["ExpandValues", "RestrictToSlotValues"],
                    "default": "ExpandValues"
                  },

                  "values": {
                    "type": "array",
                    "minItems": 1,
                    "items": {
                      "type": "object",
                      "required": ["value"],
                      "properties": {
                        "value": { "type": "string" },
                        "synonyms": {
                          "type": "array",
                          "items": { "type": "string" }
                        }
                      }
                    }
                  }
                }
              }
            },

            "intents": {
              "type": "object",
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,

                "properties": {
                  "description": { "type": "string" },

                  "intent_type": {
                    "type": "string",
                    "enum": ["Normal", "Fallback", "BuiltIn"],
                    "default": "Normal"
                  },

                  "sample_utterances": {
                    "type": "array",
                    "minItems": 1,
                    "items": { "type": "string" }
                  },

                  "initial_response": {
                    "type": "object",
                    "properties": {
                      "message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "items": { "type": "string" }
                      }
                    }
                  },

                  "dialog_code_hook": {
                    "type": "object",
                    "properties": {
                      "enabled": { "type": "boolean" }
                    }
                  },

                  "fulfillment_code_hook": {
                    "type": "object",
                    "properties": {
                      "enabled": { "type": "boolean" }
                    }
                  },

                  "fulfillment_lambda_name": {
                    "type": "string"
                  },

                  "lambda_config": {
                    "type": "object",
                    "properties": {
                      "function_name": { "type": "string" },
                      "timeout_ms": {
                        "type": "integer",
                        "minimum": 100,
                        "maximum": 30000
                      }
                    }
                  },

                  "confirmation_prompt": {
                    "type": "object",
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "maxItems": 2,
                        "items": { "type": "string" }
                      },
                      "message_selection_strategy": {
                        "type": "string",
                        "enum": ["Ordered", "Random"],
                        "default": "Ordered"
                      },
                      "max_retries": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 5
                      }
                    }
                  },

                  "confirmation_response": {
                    "type": "object",
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "items": { "type": "string" }
                      }
                    }
                  },

                  "declination_response": {
                    "type": "object",
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "items": { "type": "string" }
                      }
                    }
                  },

                  "failure_response": {
                    "type": "object",
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "items": { "type": "string" }
                      }
                    }
                  },

                  "closing_prompt": {
                    "type": "object",
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string" },
                      "ssml_message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "items": { "type": "string" }
                      }
                    }
                  },

                  "fulfillment_response": {
                    "type": "object",
                    "properties": {
                      "message": { "type": "string" },
                      "variations": {
                        "type": "array",
                        "items": { "type": "string" }
                      }
                    }
                  },

                  "contexts": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "name": { "type": "string" },
                        "time_to_live": {
                          "type": "object",
                          "properties": {
                            "time_to_live_in_seconds": { "type": "integer" },
                            "turns_to_live": { "type": "integer" }
                          }
                        }
                      }
                    }
                  },

                  "slots": {
                    "type": "object",
                    "additionalProperties": {
                      "type": "object",
                      "required": ["slot_type", "required", "prompt"],
                      "properties": {
                        "description": { "type": "string" },
                        "slot_type": { "type": "string" },
                        "required": { "type": "boolean" },

                        "prompt": { "type": "string" },

                        "prompt_variations": {
                          "type": "array",
                          "maxItems": 2,
                          "items": { "type": "string" }
                        },

                        "message_selection_strategy": {
                          "type": "string",
                          "enum": ["Ordered", "Random"],
                          "default": "Ordered"
                        },

                        "max_retries": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 5
                        },

                        "obfuscation": {
                          "type": "string",
                          "enum": ["DefaultObfuscation", "None"]
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}