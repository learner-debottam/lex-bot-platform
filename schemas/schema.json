{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Lex V2 Bot Configuration",
  "description": "Schema for bot_config JSON consumed by the lexv2-bot Terraform module.",
  "type": "object",
  "additionalProperties": false,
  "required": ["name", "idle_session_ttl", "locales"],

  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 100,
      "pattern": "^[A-Za-z0-9_-]+$"
    },

    "description": {
      "type": "string",
      "maxLength": 200
    },

    "type": {
      "type": "string",
      "enum": ["Bot", "BotNetwork"]
    },

    "idle_session_ttl": {
      "type": "integer",
      "minimum": 60,
      "maximum": 86400,
      "description": "Idle session timeout in seconds."
    },

    "child_directed": {
      "type": "boolean"
    },

    "locales": {
      "type": "object",
      "description": "Map of Lex locale IDs (e.g., en_US, en_GB) to locale configuration.",
      "minProperties": 1,
      "additionalProperties": false,

      "patternProperties": {
        "^[a-z]{2}_[A-Z]{2}$": {
          "type": "object",
          "additionalProperties": false,
          "required": ["confidence_threshold"],

          "properties": {
            "description": {
              "type": "string"
            },

            "confidence_threshold": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },

            "voice_settings": {
              "type": "object",
              "description": "Optional voice settings for this locale.",
              "additionalProperties": false,
              "required": ["voice_id"],
              "properties": {
                "voice_id": {
                  "type": "string",
                  "minLength": 1
                },
                "engine": {
                  "type": "string",
                  "enum": ["standard", "neural"]
                }
              }
            },

            "custom_vocabulary": {
              "type": "array",
              "description": "Optional custom vocabulary to improve recognition.",
              "maxItems": 100,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["phrase"],
                "properties": {
                  "phrase": {
                    "type": "string",
                    "minLength": 1,
                    "maxLength": 100,
                    "pattern": "^[A-Za-z0-9@,#\\$\\.\\'\\- ]+$"
                  },
                  "display_as": {
                    "type": "string",
                    "maxLength": 100,
                    "pattern": "^[A-Za-z0-9@,#\\$\\.\\'\\- ]*$"
                  },
                  "weight": {
                    "type": "number",
                    "minimum": 0,
                    "maximum": 3
                  }
                }
              }
            },

            "slot_types": {
              "type": "object",
              "description": "Optional custom slot types for this locale.",
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]{1,100}$"
              },
              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,
                "required": ["values"],
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "values": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 1000,
                    "items": {
                      "type": "object",
                      "required": ["value"],
                      "additionalProperties": false,
                      "properties": {
                        "value": {
                          "type": "string",
                          "minLength": 1,
                          "maxLength": 140
                        },
                        "synonyms": {
                          "type": "array",
                          "maxItems": 10,
                          "items": {
                            "type": "string",
                            "minLength": 1,
                            "maxLength": 140
                          }
                        }
                      }
                    }
                  }
                }
              },
              "value_selection_strategy": {
                "type": "string",
                "enum": ["ExpandValues", "RestrictToSlotValues"],
                "default": "ExpandValues",
                "description": "Controls whether slot accepts only predefined values or can generalize."
              }
            },
            "intents": {
              "type": "object",
              "description": "Optional intents for this locale.",
              "maxProperties": 1000,
              "propertyNames": {
                "pattern": "^[A-Za-z0-9_-]{1,100}$"
              },

              "additionalProperties": {
                "type": "object",
                "additionalProperties": false,

                "properties": {
                  "description": { "type": "string" },

                  "sample_utterances": {
                    "type": "array",
                    "minItems": 1,
                    "maxItems": 100,
                    "items": {
                      "type": "string",
                      "minLength": 1,
                      "maxLength": 200
                    }
                  },

                  "fulfillment_lambda_name": {
                    "type": "string",
                    "maxLength": 140
                  },

                  "fulfillment_code_hook": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "enabled": { "type": "boolean" }
                    }
                  },

                  "confirmation_prompt": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
                      "variations": {
                        "type": "array",
                        "maxItems": 2,
                        "items": { "type": "string", "maxLength": 1000 }
                      },
                      "message_selection_strategy": {
                        "type": "string",
                        "enum": ["Ordered", "Random"]
                      },
                      "max_retries": {
                        "type": "integer",
                        "minimum": 1,
                        "maximum": 5
                      }
                    }
                  },

                  "confirmation_response": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
                      "variations": {
                        "type": "array",
                        "maxItems": 2,
                        "items": { "type": "string", "maxLength": 1000 }
                      }
                    }
                  },

                  "declination_response": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
                      "variations": {
                        "type": "array",
                        "maxItems": 2,
                        "items": { "type": "string", "maxLength": 1000 }
                      }
                    }
                  },

                  "failure_response": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
                      "variations": {
                        "type": "array",
                        "maxItems": 2,
                        "items": { "type": "string", "maxLength": 1000 }
                      }
                    }
                  },

                  "closing_prompt": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["message"],
                    "properties": {
                      "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
                      "ssml_message": { "type": "string", "maxLength": 2000 },
                      "variations": {
                        "type": "array",
                        "maxItems": 2,
                        "items": { "type": "string", "maxLength": 1000 }
                      }
                    }
                  },

                  "slots": {
                    "type": "object",
                    "description": "Optional slots required by this intent.",
                    "propertyNames": {
                      "pattern": "^[A-Za-z0-9_-]{1,100}$"
                    },
                    "additionalProperties": {
                      "type": "object",
                      "additionalProperties": false,
                      "required": ["slot_type", "required", "prompt"],
                      "properties": {
                        "description": { "type": "string" },
                        "slot_type": { "type": "string", "minLength": 1, "maxLength": 100 },
                        "required": { "type": "boolean" },
                        "prompt": { "type": "string", "minLength": 1, "maxLength": 1000 },
                        "max_retries": {
                          "type": "integer",
                          "minimum": 1,
                          "maximum": 5
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}